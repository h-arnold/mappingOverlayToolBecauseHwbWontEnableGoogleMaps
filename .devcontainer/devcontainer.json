{
    "name": "GeoForge Map Studio",
    "build": {
        "dockerfile": "Dockerfile",
        "args": {
            "VARIANT": "24-bookworm"
        }
    },
    "features": {
        "ghcr.io/devcontainers/features/github-cli:1": {
            "version": "latest"
        }
    },

    // Configure Node.js environment
    "containerEnv": {
        "NODE_ENV": "development"
    },

    // Mount the workspace
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
    "workspaceFolder": "/workspace",

    // Install dependencies on container creation
    "postCreateCommand": "npm install",

    // Additional commands after container is ready
    "postStartCommand": "node --version && npm --version",

    // VS Code extensions useful for this project
    "customizations": {
        "vscode": {
            "extensions": [
                "bradlc.vscode-tailwindcss",
                "dbaeumer.vscode-eslint",
                "esbenp.prettier-vscode",
                "csstools.postcss",
                "eamodio.gitlens",
                "github.vscode-pull-request-github",
                "yzhang.markdown-all-in-one"
            ],
            "settings": {
                "files.associations": {
                    "*.css": "tailwindcss"
                },
                "editor.defaultFormatter": "esbenp.prettier-vscode",
                "editor.formatOnSave": true,
                "editor.codeActionsOnSave": {
                    "source.fixAll.eslint": "explicit"
                },
                "tailwindCSS.experimental.classRegex": [],
                "tailwindCSS.includeLanguages": {
                    "html": "html",
                    "javascript": "javascript"
                }
            }
        }
    },

    // Port forwarding for Vite dev server
    "forwardPorts": [5173],
    "portsAttributes": {
        "5173": {
            "label": "Vite Dev Server",
            "onAutoForward": "notify"
        }
    },

    // Remote user
    "remoteUser": "node"
}
